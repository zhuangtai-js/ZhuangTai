{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "error"
  },
  "options": {
    "typeAware": true,
    "typeCheck": true
  },
  "plugins": [
    "typescript",
    "oxc",
    "unicorn",
    "react",
    "vitest",
    "vue",
    "import",
    "jsx-a11y",
    "eslint"
  ],
  "rules": {
    "no-console": "warn",
    "func-names": "error",
    "func-style": [
      "error",
      "declaration"
    ],
    "import/no-cycle": "error",
    "import/no-default-export": "allow"
  }
}
