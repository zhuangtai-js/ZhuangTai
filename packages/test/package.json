{
  "name": "@zhuangtai-js/test",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "browser:test": "playwright install chromium && vitest --config vitest.browser.config.ts run",
    "build": "node -e \"\"",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "lint": "oxlint --type-aware . -f agent",
    "test": "vitest --config vitest.config.ts run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@zhuangtai-js/core": "workspace:*",
    "@zhuangtai-js/persist": "workspace:*"
  },
  "devDependencies": {
    "@vitest/browser-playwright": "^4.1.9",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "playwright": "^1.61.1",
    "typescript": "rc",
    "vitest": "^4.1.9"
  }
}
