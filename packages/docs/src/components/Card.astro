---
import { Card } from "@astrojs/starlight/components";

const { title, icon } = Astro.props;
---

<div
  class="relative z-0 flex h-full flex-col before:absolute before:inset-0 before:-z-10 before:rounded-2xl before:bg-[var(--sl-color-accent-low)] before:opacity-15 before:blur-[3.25rem] before:transition-opacity before:duration-300 before:content-[''] hover:before:opacity-25 [&>.card]:flex-1"
>
  <Card title={title} icon={icon}>
    <slot />
  </Card>
</div>
