---
import { Card } from "@astrojs/starlight/components";

const { title, icon } = Astro.props;
---

<div class="col-[1/-1] mt-8!">
  <Card title={title} icon={icon}>
    <div class="flex flex-col gap-6 min-[50rem]:flex-row min-[50rem]:items-start min-[50rem]:gap-12">
      <div class="mt-0! flex-1">
        <slot name="left" />
      </div>
      <div class="mt-0! flex-1">
        <slot name="right" />
      </div>
    </div>
  </Card>
</div>
