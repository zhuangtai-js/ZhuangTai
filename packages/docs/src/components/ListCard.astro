---
import { Card } from "@astrojs/starlight/components";

const { title, icon } = Astro.props;
---

<div
  class="flex h-full flex-col [&>.card]:flex-1 [&_ul]:m-0! [&_ul]:list-none [&_ul]:p-0 [&_li]:m-0! [&_li]:border-b [&_li]:border-[var(--sl-color-hairline)] [&_li:last-child]:border-b-0 [&_a]:flex [&_a]:items-center [&_a]:justify-between [&_a]:py-3 [&_a]:text-[var(--sl-color-text)] [&_a]:no-underline [&_a]:transition-colors [&_a]:duration-200 [&_a]:after:ml-3 [&_a]:after:inline-block [&_a]:after:text-xl [&_a]:after:leading-none [&_a]:after:transition-transform [&_a]:after:duration-200 [&_a]:after:content-['→'] [&_a:hover]:text-[var(--sl-color-accent)] [&_a:hover]:after:translate-x-1"
>
  <Card title={title} icon={icon}>
    <slot />
  </Card>
</div>
