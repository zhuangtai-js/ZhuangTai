{
  "name": "docs",
  "version": "0.1.0",
  "private": true,
  "description": "Documentation site for ZhuangTai.",
  "type": "module",
  "scripts": {
    "build": "astro build",
    "dev": "astro dev",
    "format": "oxfmt package.json astro.config.mjs tsconfig.json src",
    "format:check": "oxfmt package.json astro.config.mjs tsconfig.json src --check",
    "lint": "oxlint astro.config.mjs src -f agent",
    "preview": "astro preview",
    "test": "node -e \"\"",
    "typecheck": "astro sync && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.41.3",
    "@zhuangtai-js/core": "workspace:*",
    "@zhuangtai-js/persist": "workspace:*",
    "@zhuangtai-js/sync": "workspace:*",
    "astro": "^7.0.6",
    "starlight-llms-txt": "^0.11.0"
  },
  "devDependencies": {
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "typescript": "7.0.2"
  }
}
