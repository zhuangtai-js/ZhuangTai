{
  "name": "docs",
  "version": "0.1.0",
  "private": true,
  "description": "Documentation site for ZhuangTai.",
  "type": "module",
  "scripts": {
    "build": "astro build",
    "dev": "astro dev",
    "format": "oxfmt package.json astro.config.mjs tsconfig.json src test",
    "format:check": "oxfmt package.json astro.config.mjs tsconfig.json src test --check",
    "lint": "oxlint astro.config.mjs src test -f agent",
    "preview": "astro preview",
    "test": "vitest run",
    "typecheck": "astro sync && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@astrojs/react": "^6.0.1",
    "@astrojs/starlight": "^0.41.3",
    "@zhuangtai-js/core": "workspace:*",
    "@zhuangtai-js/persist": "workspace:*",
    "@zhuangtai-js/react": "workspace:*",
    "astro": "^7.0.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "starlight-llms-txt": "^0.11.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "tailwindcss": "^4.3.2",
    "typescript": "7.0.2",
    "vitest": "^4.1.10"
  }
}
