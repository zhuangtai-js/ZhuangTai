{
  "name": "@zhuangtai-js/core",
  "version": "0.3.0",
  "description": "Simple, direct state primitives for JavaScript.",
  "keywords": [
    "javascript",
    "state",
    "state-management",
    "store",
    "typescript"
  ],
  "homepage": "https://github.com/zhuangtai-js/ZhuangTai#readme",
  "bugs": {
    "url": "https://github.com/zhuangtai-js/ZhuangTai/issues"
  },
  "license": "ISC",
  "author": "mouyase",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhuangtai-js/ZhuangTai.git",
    "directory": "packages/core"
  },
  "files": [
    "CHANGELOG.md",
    "dist/index.d.ts",
    "dist/index.js"
  ],
  "type": "module",
  "sideEffects": false,
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "rslib",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node -e \"\"",
    "lint": "oxlint . -f agent",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check"
  },
  "devDependencies": {
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "typescript": "rc"
  }
}
