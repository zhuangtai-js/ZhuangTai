{
  "name": "@zhuangtai-js/core",
  "version": "0.1.0",
  "description": "Simple, direct state primitives for JavaScript.",
  "keywords": [
    "javascript",
    "state",
    "state-management",
    "store",
    "typescript"
  ],
  "homepage": "https://github.com/zhuangtai-js/ZhuangTai#readme",
  "bugs": {
    "url": "https://github.com/zhuangtai-js/ZhuangTai/issues"
  },
  "license": "ISC",
  "author": "mouyase",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhuangtai-js/ZhuangTai.git",
    "directory": "packages/core"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsgo -p tsconfig.json",
    "typecheck": "tsgo -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "oxlint --type-aware . -f agent",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260626.1",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "vitest": "^4.1.9"
  }
}
