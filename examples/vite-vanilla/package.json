{
  "name": "@zhuangtai-js/example-vite-vanilla",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "dev": "vite",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "lint": "oxlint src -f agent",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@zhuangtai-js/core": "workspace:*"
  },
  "devDependencies": {
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "typescript": "rc",
    "vite": "^8.1.4"
  }
}
